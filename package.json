{
  "name": "rune",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "desktop": "bun run --cwd apps/desktop tauri dev",
    "build": "bun run --cwd apps/desktop build",
    "check": "bun run --cwd apps/desktop check",
    "tauri": "bun run --cwd apps/desktop tauri"
  }
}
